@page "/game"

<div class="game-container">
    @if (CurrentState == null)
    {
        <div class="loading">
            <div class="loading-spinner"></div>
            <span>Loading game...</span>
        </div>
    }
    else
    {
        <div class="game-header">
            <div class="game-info">
                <span>Room: @CurrentState.RoomId</span>
                <span>Deck: @CurrentState.DeckCount cards</span>
                @if (CurrentState.Phase == GamePhase.Playing)
                {
                    <span class="turn-indicator @(IsMyTurn ? "my-turn" : "")">
                        @if (IsMyTurn)
                        {
                            <strong>YOUR TURN</strong>
                            <span class="turn-hint"> — Choose an action</span>
                        }
                        else
                        {
                            <text>@GetCurrentPlayerName()'s turn</text>
                        }
                    </span>
                }
                <button class="scoreboard-btn" @onclick="ToggleScoreboard" title="View scores">
                    🏆 Scores
                </button>
            </div>
        </div>

        @if (ShowScoreboard)
        {
            <div class="scoreboard-popup-overlay" @onclick="ToggleScoreboard">
                <div class="scoreboard-popup" @onclick:stopPropagation="true">
                    <div class="scoreboard-popup-header">
                        <h3>🏆 Scoreboard</h3>
                        <button class="close-btn" @onclick="ToggleScoreboard">✕</button>
                    </div>
                    <ScoreBoardComponent Players="@CurrentState.Players" CurrentPlayerId="@CurrentState.CurrentPlayerId" />
                    <p class="scoreboard-note">First to reach 100 points is eliminated.</p>
                </div>
            </div>
        }

        <div class="opponents-area">
            @foreach (var player in CurrentState.Players.Where(p => p.Id != GameService.PlayerId))
            {
                <div class="opponent @(player.Id == CurrentState.CurrentPlayerId ? "current-turn" : "") @(player.IsEliminated ? "eliminated" : "")">
                    <div class="opponent-name">@player.Name @(!player.IsConnected ? " (DC)" : "")</div>
                    <div class="opponent-cards">@player.CardCount cards</div>
                    <div class="opponent-score">Score: @player.Score</div>
                </div>
            }
        </div>

        <div class="table-area">
            <h3>Table Sets</h3>
            <div class="table-sets">
                @if (CurrentState.TableSets.Any())
                {
                    @foreach (var seq in CurrentState.TableSets)
                    {
                        var placedByName = CurrentState.Players.FirstOrDefault(p => p.Id == seq.PlacedByPlayerId)?.Name ?? "Unknown";
                        var myPlayer = CurrentState.Players.FirstOrDefault(p => p.Id == GameService.PlayerId);
                        var hasOpened = myPlayer?.HasOpenedSet ?? false;
                        var canAddLeft = IsMyTurn && hasOpened && SelectedCards.Count >= 1 && CanAddCardsToSequence(seq, true);
                        var canAddRight = IsMyTurn && hasOpened && SelectedCards.Count >= 1 && CanAddCardsToSequence(seq, false);
                        
                        <TableSetComponent 
                            Sequence="@seq" 
                            PlacedByName="@placedByName"
                            AllowAddToLeft="@canAddLeft"
                            AllowAddToRight="@canAddRight"
                            OnAddLeft="@(() => AddToSequence(seq.Id, true))"
                            OnAddRight="@(() => AddToSequence(seq.Id, false))" />
                    }
                }
                else
                {
                    <p class="no-sets">No sets on table yet</p>
                }
            </div>
        </div>

        @if (CurrentState.Phase == GamePhase.RoundEnd || CurrentState.Phase == GamePhase.GameOver)
        {
            <div class="round-end-overlay">
                <div class="round-end">
                    <h2>@(CurrentState.Phase == GamePhase.GameOver ? "🏆 Game Over!" : "🎉 Round Ended!")</h2>
                    <p>Winner: @GetPlayerName(CurrentState.WinnerId)</p>
                    
                    <ScoreBoardComponent Players="@CurrentState.Players" CurrentPlayerId="@CurrentState.CurrentPlayerId" />
                    
                    @if (CurrentState.Phase == GamePhase.GameOver)
                    {
                        <button @onclick="BackToLobby" class="btn btn-primary">Back to Lobby</button>
                    }
                    else
                    {
                        <button @onclick="StartNewRound" class="btn btn-primary">Start New Round</button>
                    }
                </div>
            </div>
        }

        <div class="player-area">
            <div class="player-actions">
                @if (CurrentState.Phase == GamePhase.Playing && IsMyTurn)
                {
                    @if (SelectedCards.Count == 1)
                    {
                        <button @onclick="DiscardAndDraw" class="btn btn-primary">Discard &amp; Draw</button>
                    }
                    @if (SelectedCards.Count >= 3)
                    {
                        <button @onclick="OpenSet" class="btn btn-success">Open Set (@SelectedCards.Count cards)</button>
                    }
                    <button @onclick="ClearSelection" class="btn btn-secondary">Clear Selection</button>
                }
            </div>

            <HandComponent 
                Cards="@MyHand" 
                SelectedCardIds="@SelectedCards"
                NewlyDrawnCardId="@CurrentState.NewlyDrawnCardId"
                OnCardSelected="@HandleCardSelected" />
        </div>

        @if (ShowYourTurnToast)
        {
            <div class="your-turn-toast">🎴 YOUR TURN!</div>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">@ErrorMessage</div>
        }
    }
</div>

@code {
    [Inject] private GameService GameService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private GameStateDto? CurrentState;
    private List<string> SelectedCards = new();
    private string? ErrorMessage;
    private bool ShowScoreboard = false;
    private bool ShowYourTurnToast = false;
    private string? PreviousCurrentPlayerId;
    // Toast display: 0.3s appear + 1.5s visible + 0.5s fade = 2.3s total (matches CSS animation)
    private const int YourTurnToastDurationMs = 2300;

    private bool IsMyTurn => CurrentState?.CurrentPlayerId == GameService.PlayerId;
    private List<Card> MyHand => CurrentState?.Players.FirstOrDefault(p => p.Id == GameService.PlayerId)?.Hand ?? new List<Card>();

    protected override async Task OnInitializedAsync()
    {
        if (!GameService.IsConnected)
        {
            Navigation.NavigateTo("/");
            return;
        }

        GameService.OnGameStateUpdated += HandleGameStateUpdated;
        GameService.OnError += HandleError;
        GameService.OnRoundEnded += HandleRoundEnded;

        // Use cached game state if available (handles race condition where state arrives before subscription)
        if (GameService.CurrentGameState != null)
        {
            CurrentState = GameService.CurrentGameState;
        }
    }

    private void HandleGameStateUpdated(GameStateDto state)
    {
        // Detect when it becomes this player's turn and show toast
        bool becameMyTurn = state.Phase == GamePhase.Playing
            && state.CurrentPlayerId == GameService.PlayerId
            && PreviousCurrentPlayerId != GameService.PlayerId;

        PreviousCurrentPlayerId = state.CurrentPlayerId;
        CurrentState = state;
        
        if (state.Phase == GamePhase.Lobby)
        {
            Navigation.NavigateTo("/");
        }

        if (becameMyTurn)
        {
            ShowYourTurnToast = true;
            Task.Run(async () =>
            {
                await Task.Delay(YourTurnToastDurationMs);
                ShowYourTurnToast = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string message)
    {
        ErrorMessage = message;
        InvokeAsync(StateHasChanged);
        
        Task.Run(async () =>
        {
            await Task.Delay(3000);
            ErrorMessage = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private void HandleRoundEnded(string winnerId)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task DiscardAndDraw()
    {
        if (SelectedCards.Count != 1) return;

        ErrorMessage = null;
        await GameService.DiscardAndDrawAsync(SelectedCards[0]);
        SelectedCards.Clear();
    }

    private async Task OpenSet()
    {
        if (SelectedCards.Count < 3) return;
        
        ErrorMessage = null;
        await GameService.OpenSetAsync(SelectedCards);
        SelectedCards.Clear();
    }

    private async Task AddToSequence(string sequenceId, bool addToLeft)
    {
        if (SelectedCards.Count == 0) return;
        
        ErrorMessage = null;
        await GameService.AddToSetAsync(sequenceId, SelectedCards.ToList(), addToLeft);
        SelectedCards.Clear();
    }

    private void HandleCardSelected(string cardId)
    {
        if (SelectedCards.Contains(cardId))
        {
            SelectedCards.Remove(cardId);
        }
        else
        {
            SelectedCards.Add(cardId);
        }
        StateHasChanged();
    }

    private void ToggleScoreboard()
    {
        ShowScoreboard = !ShowScoreboard;
    }

    private void ClearSelection()
    {
        SelectedCards.Clear();
    }

    private bool CanAddCardsToSequence(Sequence seq, bool toLeft)
    {
        if (SelectedCards.Count == 0) return false;
        var cards = SelectedCards
            .Select(id => MyHand.FirstOrDefault(c => c.Id == id))
            .Where(c => c != null)
            .Cast<Card>()
            .ToList();
        if (cards.Count != SelectedCards.Count) return false;

        return toLeft
            ? GameEngine.CanAddMultipleToLeft(seq, cards)
            : GameEngine.CanAddMultipleToRight(seq, cards);
    }

    private string GetCurrentPlayerName()
    {
        return CurrentState?.Players.FirstOrDefault(p => p.Id == CurrentState.CurrentPlayerId)?.Name ?? "";
    }

    private string GetPlayerName(string? playerId)
    {
        if (string.IsNullOrEmpty(playerId)) return "";
        return CurrentState?.Players.FirstOrDefault(p => p.Id == playerId)?.Name ?? "";
    }

    private async Task StartNewRound()
    {
        if (CurrentState?.RoomId != null)
        {
            await GameService.StartGameAsync(CurrentState.RoomId);
        }
    }

    private void BackToLobby()
    {
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        GameService.OnGameStateUpdated -= HandleGameStateUpdated;
        GameService.OnError -= HandleError;
        GameService.OnRoundEnded -= HandleRoundEnded;
    }
}
