@page "/"

<div class="lobby-container">
    <h1>🃏 Zero Card Game</h1>
    
    @if (string.IsNullOrEmpty(RoomId))
    {
        <div class="lobby-form">
            <input type="text" @bind="PlayerName" placeholder="Enter your name" class="lobby-input" />
            
            <div class="lobby-actions">
                <div class="action-card">
                    <h3>Create a Room</h3>
                    <p class="action-description">Start a new game and invite friends</p>
                    <div class="player-count-selector">
                        <label>Number of Players:</label>
                        <div class="player-count-buttons">
                            @for (int i = 2; i <= 6; i++)
                            {
                                var count = i;
                                <button class="player-count-btn @(MaxPlayers == count ? "selected" : "")"
                                        @onclick="() => MaxPlayers = count">@count</button>
                            }
                        </div>
                    </div>
                    <button @onclick="CreateRoom" class="btn btn-primary" disabled="@string.IsNullOrWhiteSpace(PlayerName)">
                        Create Room
                    </button>
                </div>

                <div class="action-divider"><span>OR</span></div>

                <div class="action-card">
                    <h3>Join a Room</h3>
                    <p class="action-description">Enter a room code to join an existing game</p>
                    <input type="text" @bind="JoinRoomCode" placeholder="Room Code" class="lobby-input room-code-input" maxlength="6" />
                    <button @onclick="JoinRoom" class="btn btn-secondary" disabled="@(string.IsNullOrWhiteSpace(PlayerName) || string.IsNullOrWhiteSpace(JoinRoomCode))">
                        Join Room
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="lobby-room">
            <h2>Room: <span class="room-code">@RoomId</span></h2>
            <p class="room-code-hint">Share this code with other players</p>
            
            <div class="player-list">
                <h3>Players (@(CurrentState?.Players.Count ?? 0)/@MaxPlayers)</h3>
                @if (CurrentState != null)
                {
                    @foreach (var player in CurrentState.Players)
                    {
                        <div class="player-item">
                            <span class="player-dot">●</span>
                            @player.Name @(player.Id == GameService.PlayerId ? " (You)" : "")
                        </div>
                    }
                }
            </div>
            
            @if (CurrentState?.Players.Count >= 2 && CurrentState?.Players.FirstOrDefault()?.Id == GameService.PlayerId)
            {
                <button @onclick="StartGame" class="btn btn-success">Start Game</button>
            }
            else if (CurrentState?.Players.Count < 2)
            {
                <p class="waiting-message">Waiting for more players...</p>
            }
            else
            {
                <p class="waiting-message">Waiting for host to start...</p>
            }
        </div>
    }
    
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">@ErrorMessage</div>
    }
</div>

@code {
    [Inject] private GameService GameService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private string PlayerName = "";
    private string JoinRoomCode = "";
    private string? RoomId;
    private string? ErrorMessage;
    private GameStateDto? CurrentState;
    private int MaxPlayers = 2;

    protected override async Task OnInitializedAsync()
    {
        await GameService.InitializeAsync(Navigation.ToAbsoluteUri("/gamehub").ToString());
        
        GameService.OnRoomCreated += HandleRoomCreated;
        GameService.OnRoomJoined += HandleRoomJoined;
        GameService.OnGameStateUpdated += HandleGameStateUpdated;
        GameService.OnGameStarted += HandleGameStarted;
        GameService.OnError += HandleError;
    }

    private async Task CreateRoom()
    {
        ErrorMessage = null;
        await GameService.CreateRoomAsync(PlayerName, MaxPlayers);
    }

    private async Task JoinRoom()
    {
        ErrorMessage = null;
        await GameService.JoinRoomAsync(JoinRoomCode.ToUpper(), PlayerName);
    }

    private async Task StartGame()
    {
        if (RoomId != null)
        {
            await GameService.StartGameAsync(RoomId);
        }
    }

    private void HandleRoomCreated(string roomId, string playerId)
    {
        RoomId = roomId;
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoomJoined(string roomId, string playerId)
    {
        RoomId = roomId;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameStateUpdated(GameStateDto state)
    {
        CurrentState = state;
        
        if (state.Phase == GamePhase.Playing)
        {
            Navigation.NavigateTo("/game");
        }
        
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameStarted()
    {
        Navigation.NavigateTo("/game");
    }

    private void HandleError(string message)
    {
        ErrorMessage = message;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GameService.OnRoomCreated -= HandleRoomCreated;
        GameService.OnRoomJoined -= HandleRoomJoined;
        GameService.OnGameStateUpdated -= HandleGameStateUpdated;
        GameService.OnGameStarted -= HandleGameStarted;
        GameService.OnError -= HandleError;
    }
}
