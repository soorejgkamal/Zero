<div class="card @(IsSelected ? "card-selected" : "") @(IsHighlighted ? "card-highlighted" : "") @(IsNewlyDrawn ? "card-newly-drawn" : "") @(card.IsRed ? "card-red" : "card-black")"
     @onclick="HandleClick">
    <div class="card-content">
        @if (card.IsJoker)
        {
            <div class="card-joker">🃏</div>
        }
        else
        {
            <div class="card-rank">@card.RankSymbol</div>
            <div class="card-suit">@card.SuitSymbol</div>
        }
    </div>
</div>

@code {
    [Parameter] public Card card { get; set; } = null!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsHighlighted { get; set; }
    [Parameter] public bool IsNewlyDrawn { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
    }
}
